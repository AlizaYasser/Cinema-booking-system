<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.LoginController"
      style="-fx-background-color: #111318;">

    <!-- LEFT SIDE — Cinematic Visual Panel -->
    <VBox prefWidth="420" prefHeight="600"
          alignment="CENTER" spacing="20"
          style="-fx-background-color: #0e1017;
                 -fx-border-color: #c9a84c;
                 -fx-border-width: 0 2 0 0;">

        <!-- Logo PNG instead of circle -->
        <ImageView fx:id="logoImageView"
                   fitWidth="120"
                   fitHeight="120"
                   preserveRatio="true"
                   smooth="true"
                   style="-fx-opacity: 0.85;"/>

        <VBox alignment="CENTER" spacing="8">
            <Label text="CINEVISION"
                   style="-fx-font-size: 42; -fx-text-fill: #ffffff;
                          -fx-font-weight: bold; -fx-letter-spacing: 12;"/>
            <Label text="B O O K I N G"
                   style="-fx-font-size: 16; -fx-text-fill: #c9a84c;
                          -fx-letter-spacing: 8;"/>
            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 10 0 0 0;">
                <Label text="━━━━" style="-fx-text-fill: #c9a84c; -fx-opacity: 0.6;"/>
                <Label text="✦" style="-fx-text-fill: #c9a84c;"/>
                <Label text="━━━━" style="-fx-text-fill: #c9a84c; -fx-opacity: 0.6;"/>
            </HBox>
        </VBox>

        <Label text="Your Premium Movie Experience"
               style="-fx-font-size: 13; -fx-text-fill: #c8c8d8;
                      -fx-font-style: italic;"/>

        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 20 0 0 0;">
            <Label text="ACTION" style="-fx-background-color: #1c1f2b; -fx-text-fill: #c9a84c;
                                        -fx-padding: 5 10; -fx-font-size: 10;
                                        -fx-border-color: #c9a84c; -fx-border-width: 1;"/>
            <Label text="DRAMA" style="-fx-background-color: #1c1f2b; -fx-text-fill: #a0a8c0;
                                       -fx-padding: 5 10; -fx-font-size: 10;
                                       -fx-border-color: #a0a8c0; -fx-border-width: 1;"/>
            <Label text="SCI-FI" style="-fx-background-color: #1c1f2b; -fx-text-fill: #a0a8c0;
                                        -fx-padding: 5 10; -fx-font-size: 10;
                                        -fx-border-color: #a0a8c0; -fx-border-width: 1;"/>
        </HBox>

        <Label text='"Cinema is a mirror by which we often see ourselves."'
               style="-fx-font-size: 11; -fx-text-fill: #b0b4c8;
                      -fx-font-style: italic; -fx-padding: 30 20 0 20;"/>
        <Label text="— Martin Scorsese"
               style="-fx-font-size: 10; -fx-text-fill: #c9a84c;"/>
    </VBox>

    <!-- RIGHT SIDE — Login Form -->
    <VBox prefWidth="380" alignment="CENTER" spacing="18"
          style="-fx-padding: 60 50; -fx-background-color: #111318;">

        <Label text="Welcome Back"
               style="-fx-font-size: 28; -fx-text-fill: #ffffff; -fx-font-weight: bold;"/>
        <Label text="Sign in to your account"
               style="-fx-font-size: 13; -fx-text-fill: #c8c8d8;"/>

        <HBox style="-fx-padding: 5 0;">
            <Region prefHeight="1" prefWidth="280"
                    style="-fx-background-color: #2a2d3a;"/>
        </HBox>

        <!-- Username -->
        <VBox spacing="6">
            <Label text="USERNAME"
                   style="-fx-font-size: 10; -fx-text-fill: #c9a84c;
                          -fx-letter-spacing: 2;"/>
            <TextField fx:id="usernameField" promptText="Enter your username"
                       prefWidth="280"
                       style="-fx-background-color: #1a1d26;
                              -fx-text-fill: #ffffff;
                              -fx-prompt-text-fill: #7a7f9a;
                              -fx-padding: 12 15;
                              -fx-font-size: 13;
                              -fx-border-color: #3a3f55;
                              -fx-border-width: 1;
                              -fx-border-radius: 4;
                              -fx-background-radius: 4;"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="6">
            <Label text="PASSWORD"
                   style="-fx-font-size: 10; -fx-text-fill: #c9a84c;
                          -fx-letter-spacing: 2;"/>
            <PasswordField fx:id="passwordField" promptText="Enter your password"
                           prefWidth="280"
                           style="-fx-background-color: #1a1d26;
                                  -fx-text-fill: #ffffff;
                                  -fx-prompt-text-fill: #7a7f9a;
                                  -fx-padding: 12 15;
                                  -fx-font-size: 13;
                                  -fx-border-color: #3a3f55;
                                  -fx-border-width: 1;
                                  -fx-border-radius: 4;
                                  -fx-background-radius: 4;"/>
        </VBox>

        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #e05c5c; -fx-font-size: 12;"/>

        <Button fx:id="loginBtn" text="SIGN IN →" onAction="#handleLogin"
                prefWidth="280"
                style="-fx-background-color: #c9a84c;
                       -fx-text-fill: #111318;
                       -fx-font-size: 13;
                       -fx-font-weight: bold;
                       -fx-letter-spacing: 2;
                       -fx-padding: 13 20;
                       -fx-cursor: hand;
                       -fx-background-radius: 4;"/>

        <Button text="Create New Account" onAction="#goToRegister"
                prefWidth="280"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #e8e8f0;
                       -fx-font-size: 13;
                       -fx-padding: 12 20;
                       -fx-cursor: hand;
                       -fx-border-color: #3a3f55;
                       -fx-border-width: 1;
                       -fx-border-radius: 4;
                       -fx-background-radius: 4;"/>
    </VBox>

</HBox>
