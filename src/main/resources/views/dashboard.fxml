<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.DashboardController"
      spacing="20" alignment="TOP_CENTER"
      style="-fx-background-color: #111318; -fx-padding: 40;">

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="🎟 My Bookings"
               style="-fx-font-size: 26; -fx-text-fill: #c9a84c; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="welcomeLabel"
               style="-fx-font-size: 14; -fx-text-fill: #a0a8c0;"/>
    </HBox>

    <!-- ── Booking count / status ─────────────────────────────────── -->
    <Label fx:id="bookingCountLabel"
           text="Loading..."
           style="-fx-font-size: 13; -fx-text-fill: #c9a84c;"/>

    <!-- ── Error label (hidden by default) ───────────────────────── -->
    <Label fx:id="errorLabel"
           visible="false"
           wrapText="true"
           style="-fx-font-size: 12; -fx-text-fill: #e05050;"/>

    <!-- ── Booking history table ─────────────────────────────────── -->
    <TableView fx:id="bookingTable"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #1a1d27; -fx-border-color: #2a2d3a;
                      -fx-border-radius: 8; -fx-background-radius: 8;">

        <columns>
            <TableColumn fx:id="colMovie"    text="🎬 Movie"    prefWidth="240"
                         style="-fx-text-fill: #ffffff;"/>
            <TableColumn fx:id="colCinema"   text="🏛 Cinema"   prefWidth="180"
                         style="-fx-text-fill: #ffffff;"/>
            <TableColumn fx:id="colSeat"     text="💺 Seat"     prefWidth="80"
                         style="-fx-text-fill: #ffffff;"/>
            <TableColumn fx:id="colShowtime" text="🕐 Showtime" prefWidth="140"
                         style="-fx-text-fill: #ffffff;"/>
        </columns>

        <placeholder>
            <Label text="No bookings found. Book your first movie!"
                   style="-fx-text-fill: #a0a8c0; -fx-font-size: 13;"/>
        </placeholder>
    </TableView>

    <!-- ── Action buttons ────────────────────────────────────────── -->
    <HBox spacing="16" alignment="CENTER">

        <Button text="🔄 Refresh"
                onAction="#handleRefresh"
                style="-fx-background-color: #2a2d3a; -fx-text-fill: #ffffff;
                       -fx-font-weight: bold; -fx-padding: 10 22;
                       -fx-background-radius: 6; -fx-cursor: hand;"/>

        <Button text="🎬 Book a Movie"
                onAction="#goToCinema"
                style="-fx-background-color: #c9a84c; -fx-text-fill: #111318;
                       -fx-font-weight: bold; -fx-padding: 10 22;
                       -fx-background-radius: 6; -fx-cursor: hand;"/>

        <Button text="🚪 Logout"
                onAction="#handleLogout"
                style="-fx-background-color: #3a1a1a; -fx-text-fill: #e05050;
                       -fx-font-weight: bold; -fx-padding: 10 22;
                       -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>

</VBox>
