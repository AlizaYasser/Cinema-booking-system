<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.CinemaController"
            style="-fx-background-color: #111318;"
            prefWidth="1000" prefHeight="700"
            stylesheets="@/cinema-style.css">

    <!-- HEADER -->
    <top>
        <VBox style="-fx-background-color: #0e1017;
                     -fx-border-color: #c9a84c;
                     -fx-border-width: 0 0 2 0;
                     -fx-padding: 30 50;">
            <Label text="SELECT YOUR CINEMA"
                   style="-fx-font-size: 32;
                          -fx-font-weight: bold;
                          -fx-text-fill: #ffffff;
                          -fx-letter-spacing: 4;"/>
            <Label text="Choose your preferred cinema location"
                   style="-fx-font-size: 13;
                          -fx-text-fill: #c8c8d8;
                          -fx-padding: 8 0 0 0;"/>

            <!-- Decorative line -->
            <HBox style="-fx-padding: 12 0 0 0;">
                <Region prefHeight="1" prefWidth="200"
                        style="-fx-background-color: linear-gradient(
                            from 0% 0% to 100% 0%,
                            rgba(201,168,76,0.0) 0%,
                            #c9a84c 50%,
                            rgba(201,168,76,0.0) 100%);"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox alignment="CENTER" spacing="30"
              style="-fx-padding: 50;">

            <!-- Cinema Grid with styled scrollbar -->
            <ListView fx:id="cinemaListView"
                      prefWidth="700" prefHeight="400"
                      style="-fx-background-color: #1a1d26;
                             -fx-border-color: #3a3f55;
                             -fx-border-width: 1;
                             -fx-border-radius: 6;
                             -fx-padding: 10;
                             -fx-control-inner-background: #1a1d26;
                             -fx-control-inner-background-alt: #202530;
                             -fx-text-fill: #ffffff;"/>

        </VBox>
    </center>

    <!-- FOOTER -->
    <bottom>
        <VBox spacing="15" alignment="CENTER"
              style="-fx-padding: 30 50;
                     -fx-background-color: #0e1017;
                     -fx-border-color: #c9a84c;
                     -fx-border-width: 2 0 0 0;">

            <Button fx:id="continueBtn"
                    text="CONTINUE TO MOVIES →"
                    onAction="#handleCinemaSelect"
                    prefWidth="300"
                    style="-fx-background-color: #c9a84c;
                           -fx-text-fill: #111318;
                           -fx-font-size: 13;
                           -fx-font-weight: bold;
                           -fx-letter-spacing: 2;
                           -fx-padding: 13 28;
                           -fx-cursor: hand;
                           -fx-background-radius: 4;"/>

            <Label text="Select a cinema to explore showtimes and book tickets"
                   style="-fx-font-size: 11;
                          -fx-text-fill: #c8c8d8;"/>
        </VBox>
    </bottom>

</BorderPane>
