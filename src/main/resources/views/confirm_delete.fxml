<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.ConfirmDeleteController"
      alignment="CENTER"
      spacing="20"
      prefWidth="350"
      prefHeight="220"
      style="-fx-background-color: #0e1017;
             -fx-border-color: #c9a84c;
             -fx-border-width: 1;">

    <!-- TITLE -->
    <Label text="⚠ CONFIRM DELETE"
           style="-fx-text-fill: #c9a84c;
                  -fx-font-size: 16px;
                  -fx-font-weight: bold;"/>

    <!-- MESSAGE -->
    <Label fx:id="messageLabel"
           text="Are you sure?"
           wrapText="true"
           style="-fx-text-fill: white;
                  -fx-font-size: 13px;
                  -fx-text-alignment: center;"/>

    <!-- BUTTONS -->
    <HBox spacing="15" alignment="CENTER">

        <Button text="CANCEL"
                onAction="#handleCancel"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #c8c8d8;
                       -fx-border-color: #2a2d3a;
                       -fx-border-width: 1;
                       -fx-padding: 8 20;
                       -fx-cursor: hand;"/>

        <Button text="DELETE"
                onAction="#handleDelete"
                style="-fx-background-color: #e05555;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-padding: 8 20;
                       -fx-cursor: hand;"/>
    </HBox>

</VBox>