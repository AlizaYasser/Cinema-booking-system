<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.SeatsController"
            style="-fx-background-color: #111318;">

    <!-- TOP NAV -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #0e1017;
                     -fx-padding: 15 30;
                     -fx-border-color: #2a2d3a;
                     -fx-border-width: 0 0 1 0;">
            <Button text="← Back" onAction="#goBack"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #c9a84c;
                           -fx-font-size: 13;
                           -fx-cursor: hand;
                           -fx-border-color: #c9a84c;
                           -fx-border-width: 1;
                           -fx-padding: 6 14;
                           -fx-background-radius: 2;
                           -fx-border-radius: 2;"/>
            <VBox spacing="2">
                <Label fx:id="movieTitleLabel" text="Select Seats"
                       style="-fx-font-size: 18; -fx-text-fill: #ffffff;
                              -fx-font-weight: bold;"/>
                <Label text="CHOOSE YOUR SEATS"
                       style="-fx-font-size: 9; -fx-text-fill: #c9a84c;
                              -fx-letter-spacing: 3;"/>
            </VBox>
        </HBox>
    </top>

    <center>
        <HBox style="-fx-background-color: #111318;">

            <!-- LEFT — Screen + Seats + Legend -->
            <VBox alignment="CENTER" spacing="20"
                  style="-fx-padding: 30;"
                  HBox.hgrow="ALWAYS">

                <!-- SCREEN INDICATOR -->
                <VBox alignment="CENTER" spacing="6">
                    <Label text="▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬"
                           style="-fx-text-fill: #c9a84c; -fx-font-size: 11;"/>
                    <Label text="S C R E E N"
                           style="-fx-text-fill: #c8c8d8; -fx-font-size: 11;
                                  -fx-letter-spacing: 4;"/>
                </VBox>

                <!-- SEAT GRID -->
                <GridPane fx:id="seatGrid" hgap="8" vgap="8" alignment="CENTER"/>

                <!-- LEGEND -->
                <HBox alignment="CENTER" spacing="25">
                    <HBox alignment="CENTER" spacing="8">
                        <Button style="-fx-background-color: #1a1d26;
                                       -fx-min-width: 22; -fx-min-height: 22;
                                       -fx-background-radius: 4;
                                       -fx-border-color: #3a3f55;
                                       -fx-border-width: 1;"/>
                        <Label text="Available"
                               style="-fx-text-fill: #c8c8d8; -fx-font-size: 11;"/>
                    </HBox>
                    <HBox alignment="CENTER" spacing="8">
                        <Button style="-fx-background-color: #c9a84c;
                                       -fx-min-width: 22; -fx-min-height: 22;
                                       -fx-background-radius: 4;"/>
                        <Label text="Selected"
                               style="-fx-text-fill: #c8c8d8; -fx-font-size: 11;"/>
                    </HBox>
                    <HBox alignment="CENTER" spacing="8">
                        <Button style="-fx-background-color: #3a3f55;
                                       -fx-min-width: 22; -fx-min-height: 22;
                                       -fx-background-radius: 4;"/>
                        <Label text="Booked"
                               style="-fx-text-fill: #c8c8d8; -fx-font-size: 11;"/>
                    </HBox>
                </HBox>

            </VBox>

            <!-- VERTICAL DIVIDER -->
            <Region prefWidth="1"
                    style="-fx-background-color: #2a2d3a;"/>

            <!-- RIGHT — Booking Summary Panel -->
            <VBox prefWidth="240" spacing="20" alignment="TOP_CENTER"
                  style="-fx-background-color: #0e1017;
                         -fx-padding: 35 25;">

                <!-- Gold accent line -->
                <HBox>
                    <Region prefHeight="2" prefWidth="50"
                            style="-fx-background-color: #c9a84c;"/>
                    <Region prefHeight="2" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #2a2d3a;"/>
                </HBox>

                <Label text="BOOKING SUMMARY"
                       style="-fx-font-size: 10; -fx-text-fill: #c9a84c;
                              -fx-letter-spacing: 3;"/>

                <Label text="🎬"
                       style="-fx-font-size: 36;"/>

                <Region prefHeight="1" prefWidth="190"
                        style="-fx-background-color: #2a2d3a;"/>

                <VBox spacing="6">
                    <Label text="SELECTED SEATS"
                           style="-fx-font-size: 9; -fx-text-fill: #a0a8c0;
                                  -fx-letter-spacing: 2;"/>
                    <Label fx:id="selectedSeatsLabel" text="None"
                           style="-fx-text-fill: #ffffff; -fx-font-size: 13;"
                           wrapText="true"/>
                </VBox>

                <Region prefHeight="1" prefWidth="190"
                        style="-fx-background-color: #2a2d3a;"/>

                <VBox spacing="6">
                    <Label text="TOTAL PRICE"
                           style="-fx-font-size: 9; -fx-text-fill: #a0a8c0;
                                  -fx-letter-spacing: 2;"/>
                    <Label fx:id="totalPriceLabel" text="\$0.00"
                           style="-fx-text-fill: #c9a84c; -fx-font-size: 26;
                                  -fx-font-weight: bold;"/>
                    <Label text="\$12.50 per seat"
                           style="-fx-text-fill: #a0a8c0; -fx-font-size: 10;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button fx:id="confirmBtn" text="CONFIRM BOOKING →"
                        onAction="#handleConfirm"
                        prefWidth="190"
                        style="-fx-background-color: #c9a84c;
                               -fx-text-fill: #111318;
                               -fx-font-size: 12;
                               -fx-font-weight: bold;
                               -fx-letter-spacing: 1;
                               -fx-padding: 13 10;
                               -fx-cursor: hand;
                               -fx-background-radius: 0;"/>

            </VBox>

        </HBox>
    </center>

</BorderPane>
