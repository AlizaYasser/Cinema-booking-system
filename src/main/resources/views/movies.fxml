<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.MoviesController"
            style="-fx-background-color: #111318;">

    <top>
        <VBox>
            <!-- NAV BAR -->
            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-background-color: #0e1017;
                         -fx-padding: 15 30;
                         -fx-border-color: #2a2d3a;
                         -fx-border-width: 0 0 1 0;">
                <VBox alignment="CENTER_LEFT">
                    <Label text="CINEMA"
                           style="-fx-font-size: 18; -fx-text-fill: #ffffff;
                                  -fx-font-weight: bold; -fx-letter-spacing: 6;"/>
                    <Label text="BOOKING"
                           style="-fx-font-size: 9; -fx-text-fill: #c9a84c;
                                  -fx-letter-spacing: 4;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="NOW SHOWING"
                       style="-fx-text-fill: #c9a84c; -fx-font-size: 11;
                              -fx-letter-spacing: 1; -fx-cursor: hand;"/>
                <Label text="  |  " style="-fx-text-fill: #3a3f55;"/>
                <Label text="MY BOOKINGS"
                       style="-fx-text-fill: #c8c8d8; -fx-font-size: 11;
                              -fx-letter-spacing: 1; -fx-cursor: hand;"/>

                <Region prefWidth="20"/>
                <Label fx:id="welcomeLabel" text=""
                       style="-fx-font-size: 12; -fx-text-fill: #c8c8d8;"/>
                <Button text="LOGOUT" onAction="#handleLogout"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #c9a84c;
                               -fx-font-size: 11;
                               -fx-letter-spacing: 1;
                               -fx-cursor: hand;
                               -fx-border-color: #c9a84c;
                               -fx-border-width: 1;
                               -fx-padding: 6 14;
                               -fx-background-radius: 2;
                               -fx-border-radius: 2;"/>
            </HBox>

            <!-- HERO BANNER -->
            <StackPane prefHeight="200"
                       style="-fx-background-color: #0e1017;">
                <HBox alignment="CENTER" spacing="0" style="-fx-opacity: 0.05;">
                    <Label text="                 ◎ ◎ ◎ ◎ ◎ ◎"
                           style="-fx-font-size: 60; -fx-text-fill: white;"/>
                </HBox>

                <VBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-padding: 0 0 0 40;">
                    <Label text="NOW SHOWING"
                           style="-fx-font-size: 11; -fx-text-fill: #c9a84c;
                                  -fx-letter-spacing: 4;"/>
                    <Label text="This Week's Features"
                           style="-fx-font-size: 32; -fx-text-fill: #ffffff;
                                  -fx-font-weight: bold;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="━━━━" style="-fx-text-fill: #c9a84c; -fx-opacity: 0.8;"/>
                        <Label text="Book your seats before they sell out"
                               style="-fx-font-size: 13; -fx-text-fill: #c8c8d8;
                                      -fx-font-style: italic;"/>
                    </HBox>
                </VBox>
            </StackPane>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: #111318; -fx-background-color: #111318;
                           -fx-border-color: transparent;">
            <HBox alignment="CENTER" style="-fx-padding: 35;">
                <GridPane fx:id="moviesGrid" hgap="25" vgap="25"
                          alignment="CENTER"/>
            </HBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="30"
              style="-fx-background-color: #0e1017;
                     -fx-padding: 15;
                     -fx-border-color: #2a2d3a;
                     -fx-border-width: 1 0 0 0;">
            <Label text="© 2026 Cinema Booking System"
                   style="-fx-text-fill: #a0a8c0; -fx-font-size: 11;"/>
            <Label text="✦" style="-fx-text-fill: #c9a84c;"/>
            <Label text="All rights reserved"
                   style="-fx-text-fill: #a0a8c0; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
